# --- Version control ---
.git/
.gitignore
.svn/
.hg/

# --- Node.js ---
node_modules/
npm-debug.log
yarn-debug.log

# --- Python ---
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage

# --- Go (not detected, but common) ---
/vendor/
*.test
.go-cache/

# --- Java (not detected, but common) ---
target/
*.class
.gradle/

# --- IDE/editor/project files ---
.idea/
.vscode/
*.swp
*.swo

# --- Build outputs ---
dist/
build/
out/

# --- Test and debug artifacts ---
test/
tests/
debug/
*.log

# --- Environment and secrets ---
.env
.env.*
*.env
*.pem
*.key
*.crt
*.local
*.local.*
config.local.*
*.local.yml

# --- Docker files (do not copy Docker build files into image) ---
Dockerfile*
docker-compose*

# --- Documentation and markdown ---
docs/
README*

# --- Ignore top-level markdown but keep agent-assets protocols ---
/*.md
!agent-assets/

# --- Temporary and system files ---
tmp/
temp/
*.tmp
.DS_Store

# --- Project-specific patterns ---
.next/
.prettierrc
.eslintrc.json

# --- Supabase temp and branches ---
supabase/.branches/
supabase/.temp/

# --- Python virtual environments ---
python-agent/.venv/

# --- Ignore CSV, XLSX, DOCX assets (if not needed in build) ---
*.csv
*.xlsx
*.docx

# --- Ignore lock files (per instructions) ---
# (Do NOT ignore *.lock files)

# --- Do not ignore source code or public assets ---
# (src/, public/, python-agent/app/ are NOT ignored)
