# ===========================================
# CLINIC COPILOT - ENVIRONMENT VARIABLES
# ===========================================

# Supabase Configuration
# Get these values from your Supabase project settings:
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (server-side only, NEVER expose to client)
# Required for admin operations like creating users
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================================
# AI Provider Configuration
# ===========================================
# Anthropic (Claude) - Primary AI provider
# Note: The Python agent reads ANTHROPIC_API_KEY from its own .env
# These vars are for the Next.js frontend model settings defaults
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6  # Default (use claude-opus-4-6 for max reasoning)
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001  # Default
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6  # Default (use claude-opus-4-6 for max accuracy)

# ===========================================
# Python Agent Configuration
# ===========================================
PYTHON_AGENT_URL=http://localhost:8000
# Optional alias used by shared URL helper (useful for hosted Railway agent)
# RAILWAY_PYTHON_AGENT_URL=https://your-agent-service.up.railway.app
# Reasoning depth: low, medium, high
REASONING_EFFORT=high
# Reasoning summary style: auto, concise, detailed
REASONING_SUMMARY=detailed
# Conversation history controls (effective context forwarded to agent)
CHAT_HISTORY_MESSAGE_LIMIT=400
CHAT_HISTORY_CHAR_BUDGET=1800000
# JWT secret for Python agent auth (get from Supabase dashboard)
SUPABASE_JWT_SECRET=your-jwt-secret

# ===========================================
# Application Configuration
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Resend Auth Email Hook
# ===========================================
# Used by supabase/functions/send-auth-email.
# Set these as Supabase Edge Function secrets in hosted environments:
# supabase secrets set RESEND_API_KEY=... SEND_EMAIL_HOOK_SECRET=...
RESEND_API_KEY=re_your-resend-api-key
SEND_EMAIL_HOOK_SECRET=v1,whsec_your-base64-hook-secret
AUTH_EMAIL_FROM="Copilot <auth@example.com>"
AUTH_EMAIL_REPLY_TO=support@example.com
AUTH_SUPPORT_EMAIL=support@example.com
AUTH_PRODUCT_NAME=Copilot
AUTH_EMAIL_LOGO_URL=https://your-domain.com/images/copilot-logo-gradient.png

# Resend Template IDs or aliases. If omitted, the Edge Function falls back to
# generated HTML with the same copy for development/testing.
RESEND_TEMPLATE_AUTH_RECOVERY=copilot-auth-recovery
RESEND_TEMPLATE_AUTH_MAGIC_LINK=copilot-auth-magic-link
RESEND_TEMPLATE_AUTH_SIGNUP=copilot-auth-signup
RESEND_TEMPLATE_AUTH_INVITE=copilot-auth-invite
RESEND_TEMPLATE_AUTH_EMAIL_CHANGE_CURRENT=copilot-auth-email-change-current
RESEND_TEMPLATE_AUTH_EMAIL_CHANGE_NEW=copilot-auth-email-change-new
RESEND_TEMPLATE_AUTH_REAUTHENTICATION=copilot-auth-reauthentication
RESEND_TEMPLATE_AUTH_GENERIC=copilot-auth-generic

# ===========================================
# Whop.com Payment Integration
# ===========================================
# Webhook signature validation (from Whop dashboard)
WHOP_WEBHOOK_SECRET=whsec_your-webhook-secret
# Comma-separated Whop product IDs that grant Copilot member access
# Leave empty to accept all products (dev only)
WHOP_COPILOT_PRODUCT_IDS=prod_xxx
# Optional: Whop API key for membership verification (future use)
# WHOP_API_KEY=

# ===========================================
# Optional: Analytics (Used by WS-5)
# ===========================================
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
