# Anthropic - Primary AI provider
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6  # Default (use claude-opus-4-6 for max reasoning)
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001  # Default
# ANTHROPIC_OPUS_MODEL=claude-opus-4-6  # Default (used for high-complexity routing)
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6  # Default (use claude-opus-4-6 for max accuracy)

# OpenAI - Embeddings only (Anthropic has no embeddings API)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # Default

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# Reasoning
REASONING_EFFORT=high
REASONING_SUMMARY=detailed

# History limits (effective context control)
CHAT_HISTORY_MESSAGE_LIMIT=400
CHAT_HISTORY_CHAR_BUDGET=1800000
